--- META dataId=integrity-file-dev.yml group=DEFAULT_GROUP tenant= type=yaml md5=a3f8247594b423d27277e79df2ffa644
file:
  domain: ${FILE_DOMAIN:http://127.0.0.1:9300}
  path: ${FILE_PATH:D:/integrity-supervision/uploadPath}
  prefix: ${FILE_PREFIX:/statics}

fdfs:
  enabled: ${FDFS_ENABLED:false}
  domain: ${FDFS_DOMAIN:http://127.0.0.1}
  soTimeout: ${FDFS_SO_TIMEOUT:3000}
  connectTimeout: ${FDFS_CONNECT_TIMEOUT:2000}
  trackerList: ${FDFS_TRACKER_LIST:127.0.0.1:22122}

minio:
  enabled: ${MINIO_ENABLED:true}
  url: ${MINIO_URL:http://127.0.0.1:9000}
  endpoint: ${MINIO_ENDPOINT:http://127.0.0.1:9000}
  accessKey: ${MINIO_ACCESS_KEY:minioadmin}
  secretKey: ${MINIO_SECRET_KEY:minioadmin}
  bucketName: ${MINIO_BUCKET_NAME:integrity}

referer:
  enabled: false
  allowed-domains: localhost,127.0.0.1,integrity-supervision-platform.local

