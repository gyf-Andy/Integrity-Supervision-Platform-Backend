--- META dataId=integrity-flow-dev.yml group=DEFAULT_GROUP tenant= type=yaml md5=b26ff9755bf21d5978ff52a71b36abb7
spring:
  main:
    allow-bean-definition-overriding: true
  data:
    redis:
      host: ${REDIS_HOST:redis}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}
      database: ${REDIS_DATABASE:0}
  datasource:
    driver-class-name: dm.jdbc.driver.DmDriver
    url: jdbc:dm://${DM_HOST:localhost}:${DM_PORT:5236}/${DM_DATABASE:INTEGRITY-CLOUD-FLOW}?schema=${DM_SCHEMA:INTEGRITY-CLOUD-FLOW}
    username: ${DM_USERNAME:SYSDBA}
    password: ${DM_PASSWORD:IntegritySupervision0}

mybatis-plus:
  type-aliases-package: com.integrity.flow.domain
  mapper-locations: classpath:mapper/**/*.xml

springdoc:
  gatewayUrl: http://localhost:8080/${spring.application.name}
  api-docs:
    enabled: true
  info:
    title: Flow API
    description: Flow API
    contact:
      name: Integrity-Supervision-Platform
      url: https://integrity-supervision-platform.local

warm-flow:
  enabled: true
  banner: true
  key_type: SnowId19
  ui: true
  token-name: Authorization

