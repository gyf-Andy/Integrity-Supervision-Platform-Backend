--- META dataId=integrity-system-dev.yml group=DEFAULT_GROUP tenant= type=yaml md5=4c3dc928877f6a6281c5d3d8ed9935a1
spring:
  data:
    redis:
      host: ${REDIS_HOST:redis}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}
  datasource:
    druid:
      stat-view-servlet:
        enabled: true
        loginUsername: ${DRUID_USERNAME:admin}
        loginPassword: ${DRUID_PASSWORD:123456}
    dynamic:
      druid:
        initial-size: 5
        min-idle: 5
        maxActive: 20
        maxWait: 60000
        connectTimeout: 30000
        socketTimeout: 60000
        timeBetweenEvictionRunsMillis: 60000
        minEvictableIdleTimeMillis: 300000
        validationQuery: SELECT 1 FROM DUAL
        testWhileIdle: true
        testOnBorrow: false
        testOnReturn: false
        poolPreparedStatements: true
        maxPoolPreparedStatementPerConnectionSize: 20
        filters: stat,slf4j
        connectionProperties: druid.stat.mergeSql=true;druid.stat.slowSqlMillis=5000
      datasource:
        master:
          driver-class-name: dm.jdbc.driver.DmDriver
          url: jdbc:dm://${DM_HOST:localhost}:${DM_PORT:5236}/${DM_DATABASE:INTEGRITY-CLOUD}?schema=${DM_SCHEMA:INTEGRITY-CLOUD}
          username: ${DM_USERNAME:SYSDBA}
          password: ${DM_PASSWORD:IntegritySupervision0}

mybatis-plus:
  type-aliases-package: com.integrity.system
  mapper-locations: classpath:mapper/**/*.xml

springdoc:
  gatewayUrl: http://localhost:8080/${spring.application.name}
  api-docs:
    enabled: true
  info:
    title: System API
    description: System API
    contact:
      name: Integrity-Supervision-Platform
      url: https://integrity-supervision-platform.local

