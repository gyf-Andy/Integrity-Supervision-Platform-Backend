--- META dataId=application-dev.yml group=DEFAULT_GROUP tenant= type=yaml
spring:
  autoconfigure:
    exclude: com.alibaba.druid.spring.boot3.autoconfigure.DruidDataSourceAutoConfigure
  cloud:
    sentinel:
      eager: true
      transport:
        dashboard: 127.0.0.1:8718

feign:
  sentinel:
    enabled: true
  okhttp:
    enabled: true
  httpclient:
    enabled: false
  client:
    config:
      default:
        connectTimeout: 10000
        readTimeout: 10000
  compression:
    request:
      enabled: true
      min-request-size: 8192
    response:
      enabled: true

management:
  endpoints:
    web:
      exposure:
        include: '*'
--- META dataId=application-dev.yml group=DEFAULT_GROUP tenant=public type=yaml
spring:
  autoconfigure:
    exclude: com.alibaba.druid.spring.boot3.autoconfigure.DruidDataSourceAutoConfigure
  cloud:
    sentinel:
      eager: true
      transport:
        dashboard: 127.0.0.1:8718

feign:
  sentinel:
    enabled: true
  okhttp:
    enabled: true
  httpclient:
    enabled: false
  client:
    config:
      default:
        connectTimeout: 10000
        readTimeout: 10000
  compression:
    request:
      enabled: true
      min-request-size: 8192
    response:
      enabled: true

management:
  endpoints:
    web:
      exposure:
        include: '*'
