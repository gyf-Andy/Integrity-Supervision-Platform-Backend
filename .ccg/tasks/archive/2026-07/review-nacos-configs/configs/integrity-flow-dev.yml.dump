--- META dataId=integrity-flow-dev.yml group=DEFAULT_GROUP tenant= type=yaml
spring:
  main:
    allow-bean-definition-overriding: true
  data:
    redis:
      host: redis	# docker compose: internal redis
      port: 6379
      password:
      database: 0
  datasource:
    driver-class-name: dm.jdbc.driver.DmDriver
    url: jdbc:dm://${DM_HOST:localhost}:5236/INTEGRITY-CLOUD-FLOW?schema=INTEGRITY-CLOUD-FLOW
    username: SYSDBA
    password: IntegritySupervision0

mybatis-plus:
  type-aliases-package: com.integrity.flow.domain
  mapper-locations: classpath:mapper/**/*.xml

springdoc:
  gatewayUrl: http://localhost:8080/${spring.application.name}
  api-docs:
    enabled: true
  info:
    title: Flow API
    description: Flow API
    contact:
      name: Integrity-Supervision-Platform
      url: https://integrity-supervision-platform.local

warm-flow:
  enabled: true
  banner: true
  key_type: SnowId19
  ui: true
  token-name: Authorization
