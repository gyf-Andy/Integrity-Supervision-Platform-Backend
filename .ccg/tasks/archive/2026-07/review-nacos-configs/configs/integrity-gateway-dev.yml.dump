--- META dataId=integrity-gateway-dev.yml group=DEFAULT_GROUP tenant= type=yaml
spring:
  data:
    redis:
      host: redis	# docker compose: internal redis
      port: 6379
      password:
  cloud:
    gateway:
      discovery:
        locator:
          lowerCaseServiceId: true
          enabled: true
      routes:
        - id: integrity-auth
          uri: lb://integrity-auth
          predicates:
            - Path=/auth/**
          filters:
            - name: CacheRequestBody
              args:
                bodyClass: java.lang.String
            - ValidateCodeFilter
            - StripPrefix=1
        - id: integrity-gen
          uri: lb://integrity-gen
          predicates:
            - Path=/code/**
          filters:
            - StripPrefix=1
        - id: integrity-job
          uri: lb://integrity-job
          predicates:
            - Path=/schedule/**
          filters:
            - StripPrefix=1
        - id: integrity-flow
          uri: lb://integrity-flow
          predicates:
            - Path=/flow/**
          filters:
            - StripPrefix=1
        - id: integrity-system
          uri: lb://integrity-system
          predicates:
            - Path=/system/**
          filters:
            - StripPrefix=1
        - id: integrity-file
          uri: lb://integrity-file
          predicates:
            - Path=/file/**
          filters:
            - StripPrefix=1

security:
  captcha:
    enabled: true
    type: math
  xss:
    enabled: true
    excludeUrls:
      - /system/notice
      - /flow/warm-flow/**
  ignore:
    whites:
      - /auth/logout
      - /auth/login
      - /auth/register
      - /flow/warm-flow-ui/**
      - /*/v2/api-docs
      - /*/v3/api-docs
      - /csrf

springdoc:
  webjars:
    prefix:
