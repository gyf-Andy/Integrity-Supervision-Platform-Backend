--- META dataId=integrity-gen-dev.yml group=DEFAULT_GROUP tenant= type=yaml
# spring配置
spring:
  data:
    redis:
      host: redis	# docker compose: internal redis
      port: 6379
      password:
  datasource:
    driver-class-name: dm.jdbc.driver.DmDriver
    url: jdbc:dm://${DM_HOST:localhost}:5236/INTEGRITY-CLOUD?schema=INTEGRITY-CLOUD
    username: SYSDBA
    password: IntegritySupervision0

# mybatis-plus配置
mybatis-plus:
    type-aliases-package: com.integrity.gen.domain
    mapper-locations: classpath:mapper/**/*.xml

# springdoc配置
springdoc:
  gatewayUrl: http://localhost:8080/${spring.application.name}
  api-docs:
    enabled: true
  info:
    title: '代码生成接口文档'
    description: '代码生成接口描述'
    contact:
      name: Integrity-Supervision-Platform
      url: https://integrity-supervision-platform.local

# 代码生成
gen:
  author: integrity
  packageName: com.integrity.system
  autoRemovePre: false
  tablePrefix: sys_
  allowOverwrite: false
