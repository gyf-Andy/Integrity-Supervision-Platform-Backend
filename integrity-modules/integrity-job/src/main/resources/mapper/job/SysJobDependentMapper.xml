<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.integrity.job.mapper.SysJobDependentMapper">

    <resultMap type="SysJobDependent" id="SysJobDependentResult">
        <result property="jobId" column="job_id"/>
        <result property="dependentId" column="dependent_id"/>
        <result property="createBy" column="create_by"/>
        <result property="status" column="status"/>
        <result property="batchIndex" column="batch_index"/>
    </resultMap>

    <resultMap type="SysJobVo" id="SysJobResult">
        <id property="jobId" column="job_id"/>
        <result property="jobName" column="job_name"/>
        <result property="jobGroup" column="job_group"/>
        <result property="parentId" column="parent_id"/>
        <result property="parentName" column="parent_name"/>
        <result property="batchType" column="batch_type"/>
        <result property="ifDependent" column="if_dependent"/>
        <result property="invokeTarget" column="invoke_target"/>
        <result property="cronExpression" column="cron_expression"/>
        <result property="exceptionRetryCount" column="exception_retry_count"/>
        <result property="exceptionWaitSecond" column="exception_wait_second"/>
        <result property="actuatorType" column="actuator_type"/>
        <result property="status" column="status"/>
        <result property="orderNum" column="order_num"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="jobType" column="job_type"/>
    </resultMap>

    <select id="insertSysJobDependents" parameterType="SysJobDependent">
        insert into sys_job_dependent(
        job_id,
        dependent_id,
        batch_index,
        create_by,
        create_time
        ) values
        <foreach collection="sysJobDependents" item="sysJobDependent" separator=",">
            (
            <if test="sysJobDependent.jobId != null and sysJobDependent.jobId != ''">#{sysJobDependent.jobId},</if>
            <if test="sysJobDependent.dependentId != null and sysJobDependent.dependentId != ''">
                #{sysJobDependent.dependentId},
            </if>
            <if test="sysJobDependent.batchIndex != null and sysJobDependent.batchIndex != 0">
                #{sysJobDependent.batchIndex},
            </if>
            <if test="sysJobDependent.createBy != null and sysJobDependent.createBy != ''">
                #{sysJobDependent.createBy},
            </if>
            sysdate()
            )
        </foreach>
    </select>

    <update id="updateSysJobDependent" parameterType="SysJobDependent">
        update sys_job_dependent
        <set>
            <if test="dependentId != null and dependentId != ''">dependent_id = #{dependentId},</if>
            <if test="batchIndex != null and batchIndex != 0">batch_index = #{batchIndex},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            create_time = sysdate()
        </set>
        <where>
            job_id = #{jobId}
        </where>
    </update>

    <delete id="cleanDependent">
        delete
        from sys_job_dependent
        where job_id = #{jobId}
    </delete>

    <select id="selectJobDependent" resultMap="SysJobDependentResult" parameterType="SysJobDependent">
        select * from sys_job_dependent
        <where>
            1 = 1
            <if test="jobId != null and jobId != ''">
                and job_id = #{jobId}
            </if>
            <if test="dependentId != null and dependentId != ''">
                and dependent_id = #{dependentId}
            </if>
            <if test="batchIndex != null and batchIndex != 0">
                and batch_index = #{batchIndex}
            </if>
        </where>
    </select>

    <select id="checkJobId" resultMap="SysJobDependentResult" parameterType="SysJobDependent">
        select * from sys_job_dependent
        <where>
            1 = 1
            <if test="jobId != null and jobId != ''">
                and job_id = #{jobId}
            </if>
            <if test="dependentId != null and dependentId != ''">
                and dependent_id = #{dependentId}
            </if>
            <if test="batchIndex != null and batchIndex != 0">
                and batch_index &gt; #{batchIndex}
            </if>
        </where>
    </select>

    <select id="selectJuniorDependentOpt" resultMap="SysJobDependentResult">
        SELECT *
        from sys_job_dependent
        where dependent_id = #{jobId}
        and batch_index = (SELECT min(batch_index)
        from sys_job_dependent
        where dependent_id = #{jobId})
    </select>

    <select id="selectJuniorDependent" resultMap="SysJobDependentResult">
        SELECT * from sys_job_dependent where job_id in
        <foreach collection="jobIds" item="jobId" open="(" separator="," close=")">
            #{jobId}
        </foreach>
        and batch_index = #{batchIndex}
    </select>

    <select id="selectSysJobDependent" resultType="com.integrity.job.vo.SysJobDependentVo">
        select sj.job_name as jobName,
        sj.create_by as createBy,
        sj.status as status,
        from_opt.batch_index as batchIndex,
        from_opt.create_time as createTime
        from sys_job sj
        right join
        (select *
        from sys_job_dependent
        where dependent_id = #{jobId}) from_opt
        on sj.job_id = from_opt.job_id
    </select>

    <select id="selectJobRefreshByType" resultMap="SysJobResult">
        SELECT
        sj.*
        FROM
        sys_job sj
        LEFT JOIN sys_job_dependent sjd ON sj.job_id = sjd.dependent_id
        WHERE
        sj.batch_type = #{batchType}
        AND sjd.batch_index = 1
    </select>
</mapper> 