# 运行 docker compose 前，从 docker/.env.example 复制生成此文件。

COMPOSE_PROJECT_NAME=integrity
# 如需启用 Compose 内置达梦服务，可设置为 dm；默认使用宿主机本地达梦。
COMPOSE_PROFILES=
IMAGE_PREFIX=integrity
IMAGE_TAG=dev

# 基础镜像。离线或内网环境请先导入镜像，或改为内网镜像仓库地址。
JAVA17_IMAGE=eclipse-temurin:17-jdk
NACOS_IMAGE=nacos/nacos-server:v3.2.2
REDIS_IMAGE=redis:8.8.0
NGINX_IMAGE=nginx:1.31.2
SENTINEL_IMAGE=bladex/sentinel-dashboard:1.8.7

# 可选的 Compose 托管达梦服务镜像。仅在 COMPOSE_PROFILES=dm 时使用。
DM_IMAGE=dm8_single:8.1.3.140

# Nacos
NACOS_SERVER_ADDR=nacos:8848
# 本地开发默认关闭 Nacos 鉴权；生产环境必须改为 true，并配置强密码与独立 token。
NACOS_AUTH_ENABLE=false
# Nacos 镜像启动脚本要求 token 非空；生产启用鉴权时必须更换为自定义 Base64 token。
NACOS_AUTH_TOKEN=U2VjcmV0S2V5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNDU2Nzg5
# 本地开发默认关闭 Nacos 鉴权，保持为空即可；启用鉴权时再填写账号密码。
NACOS_USERNAME=
NACOS_PASSWORD=

# 默认使用宿主机本地达梦数据库。
DM_HOST=host.docker.internal
DM_PORT=5236
DM_USERNAME=SYSDBA
DM_PASSWORD=IntegritySupervision0
DM_CONFIG_DATABASE=INTEGRITY-CONFIG
DM_CONFIG_SCHEMA=SYSDBA
DM_DATABASE=INTEGRITY-CLOUD
DM_SCHEMA=INTEGRITY-CLOUD
DM_FLOW_DATABASE=INTEGRITY-CLOUD-FLOW
DM_FLOW_SCHEMA=INTEGRITY-CLOUD-FLOW

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
# 如启用 Redis 密码，请与 docker/redis/conf/redis.conf 中的 requirepass 保持一致。
REDIS_PASSWORD=

# JVM
JAVA_OPTS=-Xms256m -Xmx512m -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

# Sentinel
SENTINEL_DASHBOARD=sentinel:8858

# MinIO
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=quay.io/minio/mc:RELEASE.2025-08-13T08-35-41Z
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=integrity
MINIO_CLIENT_ADDR=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ENABLED=true

# 本地文件存储兜底配置。
FILE_DOMAIN=http://localhost:9300
FILE_PREFIX=/statics
FILE_PATH=/home/integrity/uploadPath
FDFS_ENABLED=false
