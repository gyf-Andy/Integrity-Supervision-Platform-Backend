# 在运行 docker compose 之前，将此文件复制到 docker/.env。

COMPOSE_PROJECT_NAME=integrity
IMAGE_PREFIX=integrity
IMAGE_TAG=dev

# 离线基础镜像。在内网构建前，使用 docker load 导入这些镜像。
JAVA17_IMAGE=eclipse-temurin:17-jre
NACOS_IMAGE=nacos/nacos-server:latest
REDIS_IMAGE=redis:latest
NGINX_IMAGE=nginx:latest
SENTINEL_IMAGE=bladex/sentinel-dashboard:1.8.7
# 可选。将其设置为您的达梦镜像，并使用 --profile dm 启动 compose。
DM_IMAGE=dm8_single:latest

# Nacos
NACOS_SERVER_ADDR=nacos:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# 达梦数据库。如果数据库在 compose 外部运行，请将 DM_HOST 设置为容器可访问的主机名/IP。
# 在 Linux Docker 引擎上，host.docker.internal 由 compose 通过 host-gateway 进行映射。
DM_HOST=host.docker.internal
DM_PORT=5236
DM_USERNAME=SYSDBA
DM_PASSWORD=IntegritySupervision0
DM_CONFIG_DATABASE=INTEGRITY-CONFIG
DM_CONFIG_SCHEMA=SYSDBA
DM_DATABASE=INTEGRITY-CLOUD
DM_SCHEMA=INTEGRITY-CLOUD
DM_FLOW_DATABASE=INTEGRITY-CLOUD-FLOW
DM_FLOW_SCHEMA=INTEGRITY-CLOUD-FLOW

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
# 启用 Redis 密码时，必须与 docker/redis/conf/redis.conf 中的 requirepass 匹配。
REDIS_PASSWORD=

# JVM
JAVA_OPTS=-Xms256m -Xmx512m -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

# Sentinel
SENTINEL_DASHBOARD=sentinel:8858

# MinIO
# 如果当前网络无法从公网镜像仓库拉取，请先将镜像导入或同步到内网仓库，
# 然后把下面两个镜像地址替换为内网仓库地址。
MINIO_IMAGE=quay.io/minio/minio:latest
MINIO_MC_IMAGE=quay.io/minio/mc:latest
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=integrity
MINIO_CLIENT_ADDR=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ENABLED=true

# 本地文件存储兜底配置；文件服务的静态资源映射仍需要这些配置。
FILE_DOMAIN=http://localhost:9300
FILE_PREFIX=/statics
FILE_PATH=/home/integrity/uploadPath
FDFS_ENABLED=false
